<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:paddingTop="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Saved Sessions"
        android:textAppearance="?attr/textAppearanceHeadline6"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/tv_sessions_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tap a session to review its logs"
        android:textAppearance="?attr/textAppearanceCaption"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No sessions recorded yet.\nStart recording in the Playground."
        android:textAppearance="?attr/textAppearanceBody2"
        android:gravity="center"
        android:paddingTop="48dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_sessions"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"/>

</LinearLayout>
