<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:paddingTop="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Data Settings"
        android:textAppearance="?attr/textAppearanceHeadline6"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Export Format"
        android:textAppearance="?attr/textAppearanceSubtitle2"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rg_format"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp">

        <RadioButton
            android:id="@+id/rb_json"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JSON"
            android:padding="8dp"/>

        <RadioButton
            android:id="@+id/rb_csv"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="CSV"
            android:padding="8dp"/>
    </RadioGroup>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Storage Backend"
        android:textAppearance="?attr/textAppearanceSubtitle2"
        android:layout_marginBottom="8dp"/>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switch_sql"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enable SQL Database"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Beta feature — may have bugs, disable to use in-memory list"
        android:textAppearance="?attr/textAppearanceCaption"/>

</LinearLayout>
